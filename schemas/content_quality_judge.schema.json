{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ContentQualityJudgeReview",
  "type": "object",
  "required": [
    "ticker",
    "quality_score",
    "grade",
    "company_understanding_score",
    "business_model_score",
    "financial_interpretation_score",
    "money_flow_score",
    "blueprint_fit_score",
    "valuation_fit_score",
    "risk_score",
    "data_gap_score",
    "chart_table_score",
    "language_score",
    "unsupported_claims_score",
    "hard_failures",
    "specific_issues",
    "rewrite_required_sections",
    "training_case_type",
    "human_review_required"
  ],
  "properties": {
    "ticker": {"type": "string"},
    "quality_score": {"type": "integer", "minimum": 0, "maximum": 100},
    "grade": {"enum": ["EXCELLENT", "GOOD", "ACCEPTABLE", "WEAK", "FAIL"]},
    "company_understanding_score": {"type": "integer"},
    "business_model_score": {"type": "integer"},
    "financial_interpretation_score": {"type": "integer"},
    "money_flow_score": {"type": "integer"},
    "blueprint_fit_score": {"type": "integer"},
    "valuation_fit_score": {"type": "integer"},
    "risk_score": {"type": "integer"},
    "data_gap_score": {"type": "integer"},
    "chart_table_score": {"type": "integer"},
    "language_score": {"type": "integer"},
    "unsupported_claims_score": {"type": "integer"},
    "hard_failures": {"type": "array", "items": {"type": "string"}},
    "specific_issues": {"type": "array", "items": {"type": "string"}},
    "rewrite_required_sections": {"type": "array", "items": {"type": "string"}},
    "training_case_type": {"type": "string"},
    "human_review_required": {"type": "boolean"}
  }
}
